# service config
PORT=3000

# frontend config
ENABLE_SELF_HOSTED_FRONTEND=true
# URL the OAuth callback redirects to after auth (your frontend app)
FRONT_END_URL=http://localhost:3000
# Browser origins allowed to call the API with credentials (cookies). Set this
# when the frontend is a SEPARATE origin from this backend, e.g.
# CORS_ALLOWED_ORIGINS=https://faucet.ar.io  (backend at https://faucet.services.ar-io.dev).
# Comma-separated; defaults to FRONT_END_URL.
# CORS_ALLOWED_ORIGINS=

# solana config
# JSON-RPC endpoint the faucet transfers on (default devnet)
SOLANA_RPC_URL=https://api.devnet.solana.com
# base58 SPL token mint address the faucet dispenses (required)
SOLANA_TOKEN_MINT=<spl-token-mint-address>
# faucet keypair secret: base58-encoded 64-byte secret key OR JSON uint8 array (required)
SOLANA_FAUCET_SECRET_KEY=<base58-secret-or-json-array>
# optional: path to a file holding the secret key (takes precedence over the inline var)
# SOLANA_FAUCET_SECRET_KEY_FILE=./wallets/solana-faucet.json
# the key used in the supportedProcesses map / accepted as processId in requests
SOLANA_TOKEN_ID=solana-devnet
# optional: if unset the faucet reads mint decimals from chain at boot
# SOLANA_TOKEN_DECIMALS=6
# commitment level for send/confirm
SOLANA_COMMITMENT=confirmed

# auth token signing (HS256 service JWT) (required)
AUTH_TOKEN_SECRET=<random-hs256-secret>

# github oauth gate config
GITHUB_OAUTH_ENABLED=true
# required when the gate is enabled
GITHUB_CLIENT_ID=<github-oauth-app-client-id>
GITHUB_CLIENT_SECRET=<github-oauth-app-client-secret>
GITHUB_OAUTH_CALLBACK_URL=https://faucet.example.com/api/auth/github/callback
# reject GitHub accounts younger than this many days (default 30)
GITHUB_MIN_ACCOUNT_AGE_DAYS=30
# TTL for the CSRF state value (default 600)
GITHUB_OAUTH_STATE_TTL_SECONDS=600
# for testability / GitHub Enterprise
GITHUB_API_BASE_URL=https://api.github.com
GITHUB_OAUTH_AUTHORIZE_URL=https://github.com/login/oauth/authorize
GITHUB_OAUTH_TOKEN_URL=https://github.com/login/oauth/access_token

# token config (values are in SPL base units — retune for your mint decimals)
# DEFAULT_FAUCET_TOKEN_EXPIRATION_SECONDS=3600
# DEFAULT_FAUCET_TOKEN_TRANSFER_QTY=10000000000
# DEFAULT_MIN_FAUCET_TOKEN_TRANSFER_QTY=10000000
# DEFAULT_MAX_FAUCET_TOKEN_TRANSFER_QTY=10000000000

# captcha config
REQUIRE_CAPTCHA_VERIFICATION=true
CAPTCHA_SECRET_KEY=<hcaptcha-secret-key>
CAPTCHA_SITE_VERIFY_URL=<hcaptcha-site-verify-url>
CAPTCHA_SITE_KEY=<hcaptcha-site-key>

# logging config
LOG_LEVEL=info
LOG_FORMAT=json

# rate limiting config
GLOBAL_RATE_LIMIT_WINDOW_SECONDS=3600 # 1 hour
GLOBAL_RATE_LIMIT_THRESHOLD=10 # requests per window
CAPTCHA_RATE_LIMIT_WINDOW_SECONDS=3600 # 1 hour
CAPTCHA_RATE_LIMIT_THRESHOLD=1 # requests per window

# Cookie SameSite. Set "none" when the frontend is a DIFFERENT site than this
# backend (frontend faucet.ar.io + backend faucet.services.ar-io.dev); "none" needs COOKIE_SECURE=true.
# COOKIE_SAMESITE=lax
