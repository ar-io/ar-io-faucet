{
	"name": "ar-io-testnet-faucet",
	"version": "1.0.0",
	"description": "Simple koa based service for facilitating the AR.IO Testnet Network.",
	"main": "dist/app.js",
	"author": "info@pds.inc",
	"type": "module",
	"license": "AGPL-3.0-or-later",
	"private": false,
	"dependencies": {
		"@ar.io/sdk": "^3.9.1",
		"@dha-team/arbundles": "^1.0.1",
		"@koa/cors": "^5.0.0",
		"@permaweb/aoconnect": "^0.0.77",
		"axios": "^1.8.4",
		"dotenv": "^16.4.7",
		"dotenv-cli": "^8.0.0",
		"koa": "^2.16.0",
		"koa-bodyparser": "^4.4.1",
		"koa-ratelimit": "^5.1.0",
		"koa-router": "^13.0.1",
		"node-cache": "^5.1.2",
		"winston": "^3.17.0"
	},
	"devDependencies": {
		"@biomejs/biome": "1.9.4",
		"@swc/core": "^1.11.13",
		"@swc/wasm": "^1.11.13",
		"@types/koa": "^2.15.0",
		"@types/koa-bodyparser": "^4.3.12",
		"@types/koa-ratelimit": "^5.0.5",
		"@types/koa-router": "^7.4.8",
		"@types/koa__cors": "^5.0.0",
		"@types/node": "^22.13.14",
		"lint-staged": "^15.5.0",
		"nodemon": "^3.1.9",
		"simple-git-hooks": "^2.12.1",
		"testcontainers": "^10.23.0",
		"ts-node": "^10.9.2",
		"typescript": "^5.8.2"
	},
	"scripts": {
		"start": "node dist/app.js",
		"start:watch": "nodemon",
		"build": "yarn clean && yarn && npx tsc --project ./tsconfig.json",
		"clean": "rm -rf dist",
		"lint:fix": "biome check --write --unsafe",
		"lint:check": "biome check --unsafe",
		"format:fix": "biome format --write",
		"format:check": "biome format",
		"test": "yarn test:e2e",
		"test:e2e": "node --import ./register.mjs --test tests/**/**.test.ts",
		"prepare": "simple-git-hooks"
	},
	"simple-git-hooks": {
		"pre-commit": "npx lint-staged"
	},
	"lint-staged": {
		"*.{js,ts,md}": ["yarn lint:fix", "yarn format:fix"]
	},
	"packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
