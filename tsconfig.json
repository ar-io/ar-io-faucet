{
	"compilerOptions": {
		"target": "ESNext",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"declaration": false,
		"outDir": "./dist",
		"strict": true,
		"esModuleInterop": true,
		"resolveJsonModule": true,

		/* Additional Checks */
		"pretty": true,
		"sourceMap": false,
		"noFallthroughCasesInSwitch": true,
		"noImplicitAny": true,
		"noImplicitReturns": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,

		/* Temporary workaround until @ar.io/sdk is fixed */
		"skipLibCheck": true
	},
	"ts-node": {
		"swc": true,
		"esm": true
	},
	"include": ["src", "test", "scripts"]
}
