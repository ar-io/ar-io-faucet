<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>AR.IO Testnet Token Captcha</title>
  <script src="https://js.hcaptcha.com/1/api.js" async defer></script>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 font-sans">
  <div class="max-w-md mx-auto p-6">
    <h1 class="text-2xl font-bold text-gray-800 mb-2 text-center">AR.IO Testnet Token Captcha</h1>
    <p class="text-gray-600 mb-6 text-center">Complete the captcha below to request an authorization token.</p>
    
    <div class="bg-white rounded-lg shadow-md p-6">
      <form id="captchaForm">
        <div class="mb-4">
          <label for="processId" class="block text-sm font-medium text-gray-700 mb-1">Process ID:</label>
          <input type="text" id="processId" name="processId" value="<%= processId %>" disabled required 
                 class="w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-indigo-500 focus:border-indigo-500">
        </div>
        
        <div class="mb-6">
          <div class="h-captcha" data-sitekey="<%= captchaSiteKey %>"></div>
        </div>
        
        <button type="submit" id="submitBtn" 
                class="w-full bg-indigo-600 text-white py-2 px-4 rounded-md hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-colors">
          Submit
        </button>
      </form>
      
      <div id="resultContainer" class="mt-4 p-4 rounded-md hidden">
        <p id="resultMessage" class="text-sm"></p>
        <div id="tokenContainer" class="mt-2 mb-2 hidden">
          <span id="tokenExpiry" class="text-sm text-gray-700 mb-1"></span>
          <div id="tokenDisplay" class="bg-gray-100 text-gray-800 p-2 rounded-md text-xs font-mono break-all"></div>
          <button id="copyToken" class="text-sm text-blue-600 hover:text-blue-800">Copy to clipboard</button>
        </div>
      </div>
    </div>
  </div>

  <script>
    document.getElementById('captchaForm').addEventListener('submit', async function(e) {
      e.preventDefault();
      
      const processId = document.getElementById('processId').value;
      const captchaResponse = hcaptcha.getResponse();
      
      if (!captchaResponse) {
        showResult('Please complete the captcha first.', false);
        return;
      }
      
      try {
        const response = await fetch('/api/captcha/verify', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({
            processId: processId,
            captchaResponse: captchaResponse
          })
        });
        
        const data = await response.json();
        
        if (response.ok) {
          showResult({ message: 'Success!', success: true, token: data.token, expiresAt: data.expiresAt });
        } else {
          showResult({ message: 'Error: ' + (data.error || 'Unknown error occurred'), success: false });
        }
      } catch (error) {
        showResult({ message: 'Error: ' + error.message, success: false });
      }
      
      // Reset captcha
      hcaptcha.reset();
    });
    
    function showResult(result) {
      const resultContainer = document.getElementById('resultContainer');
      const resultMessage = document.getElementById('resultMessage');
      
      resultMessage.textContent = result.message;
      resultContainer.classList.remove('hidden', 'bg-green-50', 'border-green-200', 'text-green-800', 'bg-red-50', 'border-red-200', 'text-red-800');
      
      if (result.success) {
        resultContainer.classList.add('bg-green-50', 'border', 'border-green-200', 'text-green-800');
        const tokenContainer = document.getElementById('tokenContainer');
        const tokenDisplay = document.getElementById('tokenDisplay');
        const copyToken = document.getElementById('copyToken');
        tokenContainer.classList.remove('hidden');
        tokenDisplay.textContent = result.token;
        tokenExpiry.textContent = `Expiration: ${new Date(result.expiresAt).toLocaleString()}`;
      } else {
        resultContainer.classList.add('bg-red-50', 'border', 'border-red-200', 'text-red-800');
      }
      
      resultContainer.classList.remove('hidden');
    }

     // Copy token to clipboard
        document.getElementById('copyToken').addEventListener('click', function() {
            const tokenText = document.getElementById('tokenDisplay').textContent;
            navigator.clipboard.writeText(tokenText).then(function() {
                this.textContent = 'Copied!';
                setTimeout(() => {
                    this.textContent = 'Copy to clipboard';
                }, 2000);
            }.bind(this));
        });
  </script>
</body>
</html>

