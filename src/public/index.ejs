<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <link rel="icon" href="https://ar.io/brand/ario-black.svg" type="image/svg+xml">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Request test tokens for the ar.io Testnet">
    <meta name="twitter:card" content="summary">
    <meta name="twitter:title" content="ar.io Testnet Faucet">
    <meta name="twitter:description" content="Request test tokens for the ar.io Testnet">
    <meta name="twitter:image" content="https://ar.io/brand/ario-black-on-white-square.png">
    <meta name="twitter:url" content="https://faucet.ar.io">
    <meta property="og:image" content="https://ar.io/brand/ario-black-on-white-square.png">
    <meta property="og:title" content="ar.io Testnet Faucet">
    <meta property="og:description" content="Request test tokens for the ar.io Testnet">
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://faucet.ar.io">
    <title>ar.io Testnet Faucet</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Besley:wght@600;700;800&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <% if (captchaSiteKey) { %>
    <script src="https://js.hcaptcha.com/1/api.js" async defer></script>
    <% } %>

    <style>
        :root {
            --primary: #5427C8;
            --primary-deep: #45209f;
            --lavender: #DFD6F7;
            --lavender-wash: #f1ecff;
            --dark-accent-lavender: #D4C6FF;
            --black: #23232D;
            --white: #FFFFFF;
            --card: #F0F0F0;
            --warm-neutral: #F6F4EF;
            --body-gray: #4A4A58;
            --muted: #6f6c7d;
            --border: #E6E4EF;
            --success: #1F8A5B;
            --success-bg: #E8F6EF;
            --success-border: #BFE6D2;
            --error: #C0392B;
            --error-bg: #FBEBE9;
            --error-border: #F3C9C4;
            --shadow-primary: rgba(84, 39, 200, 0.28);
        }

        * { box-sizing: border-box; }
        html, body { margin: 0; padding: 0; }

        body {
            min-height: 100vh;
            font-family: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            color: var(--black);
            background:
                radial-gradient(1100px 560px at 12% -12%, #f3eeff 0%, rgba(243,238,255,0) 60%),
                radial-gradient(1000px 520px at 104% -8%, #e9deff 0%, rgba(233,222,255,0) 55%),
                linear-gradient(180deg, var(--warm-neutral) 0%, #ECE4FB 55%, var(--lavender) 100%);
            background-attachment: fixed;
            -webkit-font-smoothing: antialiased;
            text-rendering: optimizeLegibility;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 44px 20px 36px;
        }

        .brand { margin-bottom: 30px; }
        .brand img { height: 32px; width: auto; display: block; }

        header { text-align: center; margin-bottom: 26px; max-width: 560px; }
        .eyebrow {
            display: inline-flex; align-items: center; gap: 7px;
            font-size: 0.7rem; font-weight: 700; letter-spacing: 0.09em; text-transform: uppercase;
            color: var(--primary);
            background: var(--lavender-wash);
            border: 1px solid var(--dark-accent-lavender);
            padding: 5px 12px; border-radius: 999px; margin-bottom: 18px;
        }
        .eyebrow .dot { width: 6px; height: 6px; border-radius: 50%; background: var(--primary); }
        header h1 {
            font-family: 'Besley', Georgia, serif;
            font-weight: 800; font-size: 2.5rem; line-height: 1.08;
            letter-spacing: -0.015em; margin: 0 0 12px; color: var(--black);
        }
        header p { font-size: 0.98rem; line-height: 1.55; color: var(--body-gray); margin: 0 auto; max-width: 460px; }
        header a { color: var(--primary); text-decoration: none; font-weight: 600; }
        header a:hover { text-decoration: underline; }

        .card {
            position: relative;
            width: 100%; max-width: 560px;
            background: var(--white);
            border: 1px solid var(--border);
            border-radius: 22px;
            box-shadow: 0 32px 64px -34px rgba(35, 35, 45, 0.30), 0 2px 8px rgba(35, 35, 45, 0.04);
            padding: 32px 30px;
            overflow: hidden;
        }
        .card::before {
            content: ""; position: absolute; top: 0; left: 0; right: 0; height: 5px;
            background: linear-gradient(90deg, var(--primary) 0%, #7c56e0 50%, var(--dark-accent-lavender) 100%);
        }

        form { display: flex; flex-direction: column; gap: 19px; }

        label {
            display: block; font-size: 0.82rem; font-weight: 600;
            color: var(--black); margin-bottom: 8px; letter-spacing: 0.005em;
        }

        input[type="text"], input[type="number"], select {
            width: 100%; padding: 12px 14px;
            font-family: inherit; font-size: 0.95rem; color: var(--black);
            background: var(--white); border: 1px solid var(--border); border-radius: 12px;
            transition: border-color 0.15s, box-shadow 0.15s;
        }
        input::placeholder { color: #a6a3b3; }
        input:focus, select:focus {
            outline: none; border-color: var(--primary);
            box-shadow: 0 0 0 3.5px rgba(84, 39, 200, 0.16);
        }

        .token-field { position: relative; }
        .token-field img {
            position: absolute; left: 13px; top: 50%; transform: translateY(-50%);
            height: 21px; width: 21px; pointer-events: none;
        }
        .token-field select { padding-left: 42px; appearance: none; -webkit-appearance: none; cursor: pointer; }
        .token-field .chev { position: absolute; right: 14px; top: 50%; transform: translateY(-50%); pointer-events: none; color: var(--muted); }

        .github-gate {
            background: linear-gradient(150deg, var(--warm-neutral) 0%, var(--lavender-wash) 100%);
            border: 1px solid var(--border); border-radius: 14px; padding: 16px;
        }
        .github-btn {
            display: inline-flex; align-items: center; justify-content: center; gap: 9px; width: 100%;
            padding: 12px 16px; font-family: inherit; font-size: 0.92rem; font-weight: 600;
            color: var(--white); background: var(--black); border-radius: 11px; text-decoration: none;
            transition: background 0.15s, transform 0.05s;
        }
        .github-btn:hover { background: #34343f; }
        .github-btn:active { transform: translateY(1px); }
        .github-btn svg { width: 18px; height: 18px; fill: currentColor; }
        .github-status { display: flex; align-items: center; gap: 6px; margin: 11px 0 0; font-size: 0.78rem; color: var(--muted); }
        .github-status svg { width: 13px; height: 13px; flex-shrink: 0; }
        .github-status.done { color: var(--success); font-weight: 600; }
        .field-hint { margin: 7px 0 0; font-size: 0.76rem; color: var(--muted); }
        .gate-help { margin: 9px 0 0; font-size: 0.76rem; color: var(--muted); }
        .error-help { margin: 8px 0 0; font-size: 0.8rem; color: var(--body-gray); }
        .field-hint a, .gate-help a, .error-help a { color: var(--primary); font-weight: 600; text-decoration: none; }
        .field-hint a:hover, .gate-help a:hover, .error-help a:hover { text-decoration: underline; }
        .github-signedin {
            display: flex; align-items: center; gap: 9px;
            background: var(--success-bg); border: 1px solid var(--success-border);
            border-radius: 14px; padding: 13px 16px;
            font-size: 0.88rem; font-weight: 600; color: var(--success);
        }
        .github-signedin svg { width: 19px; height: 19px; flex-shrink: 0; }
        #githubUserLabel { font-weight: 700; }

        .h-captcha { margin-top: 4px; display: flex; justify-content: center; }

        .submit-btn {
            display: inline-flex; align-items: center; justify-content: center; gap: 8px; width: 100%;
            padding: 14px 16px; margin-top: 4px;
            font-family: inherit; font-size: 0.98rem; font-weight: 700; color: var(--white);
            background: linear-gradient(180deg, #5f34d2 0%, var(--primary-deep) 100%);
            border: none; border-radius: 12px; cursor: pointer;
            box-shadow: 0 12px 26px -10px var(--shadow-primary);
            transition: transform 0.06s, box-shadow 0.15s, filter 0.15s;
        }
        .submit-btn:hover { filter: brightness(1.06); box-shadow: 0 16px 30px -10px var(--shadow-primary); }
        .submit-btn:active { transform: translateY(1px); }
        .submit-btn:disabled { opacity: 0.65; cursor: not-allowed; box-shadow: none; filter: none; }

        .spinner { animation: spin 0.8s linear infinite; width: 18px; height: 18px; }
        @keyframes spin { to { transform: rotate(360deg); } }
        .hidden { display: none !important; }

        .result, .error-box { margin-top: 22px; padding: 18px; border-radius: 14px; }
        .result { background: var(--success-bg); border: 1px solid var(--success-border); }
        .result h3 { margin: 0 0 4px; font-size: 1rem; color: var(--success); font-weight: 700; }
        .error-box { background: var(--error-bg); border: 1px solid var(--error-border); }
        .error-box h3 { margin: 0 0 6px; font-size: 1rem; color: var(--error); font-weight: 700; }
        .result p, .error-box p { margin: 6px 0; font-size: 0.85rem; color: var(--body-gray); }
        .mono {
            font-family: 'SFMono-Regular', ui-monospace, Menlo, Consolas, monospace; font-size: 0.78rem;
            background: var(--white); border: 1px solid var(--border); padding: 9px; border-radius: 8px;
            word-break: break-all; color: var(--black);
        }
        .link-btn { background: none; border: none; padding: 0; cursor: pointer; font-family: inherit; font-size: 0.82rem; font-weight: 600; color: var(--primary); }
        .link-btn:hover { text-decoration: underline; }
        .result a { color: var(--primary); font-weight: 600; font-size: 0.82rem; word-break: break-all; }

        .whats-next { margin-top: 16px; padding-top: 16px; border-top: 1px solid var(--success-border); }
        .wn-title { margin: 0 0 10px; font-size: 0.9rem; font-weight: 700; color: var(--black); }
        .result a.wn-primary {
            display: inline-flex; align-items: center; justify-content: center; gap: 6px; width: 100%;
            padding: 11px 16px; font-size: 0.9rem; font-weight: 700; color: var(--white);
            background: linear-gradient(180deg, #5f34d2 0%, var(--primary-deep) 100%);
            border-radius: 11px; text-decoration: none;
            box-shadow: 0 10px 22px -10px var(--shadow-primary);
            transition: filter 0.15s, transform 0.06s;
        }
        .result a.wn-primary:hover { filter: brightness(1.06); text-decoration: none; }
        .result a.wn-primary:active { transform: translateY(1px); }
        .wn-hint { margin: 9px 0 0; font-size: 0.78rem; color: var(--body-gray); }
        .wn-links { margin: 13px 0 0; display: flex; flex-wrap: wrap; gap: 7px 16px; }
        .wn-links a { font-size: 0.82rem; font-weight: 600; color: var(--primary); text-decoration: none; }
        .wn-links a:hover { text-decoration: underline; }

        .endpoints {
            width: 100%; max-width: 560px; margin-top: 18px;
            background: var(--white); border: 1px solid var(--border);
            border-radius: 16px; padding: 18px 22px;
        }
        .endpoints-title { margin: 0 0 3px; font-size: 0.82rem; font-weight: 700; color: var(--black); }
        .endpoints-sub { margin: 0 0 13px; font-size: 0.74rem; color: var(--muted); }
        .endpoints ul { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 9px; }
        .endpoints li { display: flex; align-items: baseline; justify-content: space-between; gap: 12px; }
        .endpoints li span { color: var(--body-gray); font-weight: 600; font-size: 0.82rem; white-space: nowrap; }
        .endpoints li a {
            color: var(--primary); font-weight: 600; text-decoration: none; word-break: break-all; text-align: right;
            font-family: 'SFMono-Regular', ui-monospace, Menlo, Consolas, monospace; font-size: 0.78rem;
        }
        .endpoints li a:hover { text-decoration: underline; }
        .ids-divider { height: 1px; background: var(--border); margin: 16px 0; }
        .ids { display: flex; flex-direction: column; gap: 9px; }
        .id-row { display: flex; align-items: center; justify-content: space-between; gap: 14px; }
        .id-row > span { font-size: 0.76rem; font-weight: 700; color: var(--body-gray); white-space: nowrap; flex-shrink: 0; }
        .id-val {
            font-family: 'SFMono-Regular', ui-monospace, Menlo, Consolas, monospace; font-size: 0.73rem;
            color: var(--black); background: var(--warm-neutral); border: 1px solid var(--border);
            border-radius: 7px; padding: 5px 8px; word-break: break-all; cursor: pointer; transition: border-color 0.15s;
        }
        .id-val:hover { border-color: var(--dark-accent-lavender); }
        .id-val.copied::after { content: ' ✓ copied'; color: var(--success); font-weight: 700; white-space: nowrap; }

        footer { margin-top: 30px; font-size: 0.8rem; color: var(--muted); text-align: center; }
        footer .links { margin-bottom: 8px; display: flex; flex-wrap: wrap; justify-content: center; align-items: center; gap: 2px 0; }
        footer a { color: var(--body-gray); text-decoration: none; font-weight: 600; }
        footer a:hover { color: var(--primary); }
        footer .sep { margin: 0 9px; color: var(--dark-accent-lavender); }
        footer .copy { color: #9a97a8; margin-top: 2px; }
        footer .copy a { color: #9a97a8; }
        footer .copy a:hover { color: var(--primary); }

        @media (max-width: 560px) {
            body { padding: 32px 16px 28px; }
            header h1 { font-size: 2rem; }
            .card { padding: 24px 20px; }
            .id-row { flex-direction: column; align-items: flex-start; gap: 4px; }
        }
    </style>
</head>
<body>
    <div class="brand">
        <img src="https://ar.io/brand/ario-full-black.svg" alt="ar.io" />
    </div>

    <header>
        <span class="eyebrow"><span class="dot"></span>Solana Devnet</span>
        <h1>Testnet Faucet</h1>
        <p>Request tokens for the ar.io Testnet. Restrictions apply &mdash; see <a href="https://docs.ar.io" target="_blank" rel="noopener">docs.ar.io</a> for details.</p>
    </header>

    <main class="card">
        <form id="tokenRequestForm">
            <div>
                <label for="recipient">Solana Wallet Address (base58)</label>
                <input type="text" id="recipient" name="recipient" required minlength="32" maxlength="44"
                    pattern="^[1-9A-HJ-NP-Za-km-z]+$" placeholder="Enter a Solana devnet address"
                    title="Must be a valid base58 Solana address (32-44 characters)">
                <p class="field-hint">This wallet needs devnet SOL for fees &mdash; get some from the <a href="https://faucet.solana.com" target="_blank" rel="noopener">Solana faucet</a>.</p>
            </div>

            <div>
                <label for="processId">Token</label>
                <div class="token-field">
                    <img src="https://ar.io/brand/ario-token-logo.svg" alt="ARIO" />
                    <select id="processId" name="processId" required>
                        <option value="<%= tokenId %>"><%= tokenId %></option>
                    </select>
                    <svg class="chev" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </div>
            </div>

            <div id="githubGate" class="github-gate hidden">
                <a id="githubLoginLink" href="#" class="github-btn">
                    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 .5C5.73.5.5 5.73.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.56 0-.28-.01-1.02-.02-2-3.2.7-3.88-1.54-3.88-1.54-.52-1.33-1.28-1.68-1.28-1.68-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.7 1.26 3.36.96.1-.75.4-1.26.73-1.55-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.29 1.19-3.1-.12-.29-.52-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11.1 11.1 0 0 1 2.9-.39c.98 0 1.97.13 2.9.39 2.2-1.49 3.17-1.18 3.17-1.18.63 1.59.23 2.76.11 3.05.74.81 1.19 1.84 1.19 3.1 0 4.42-2.69 5.39-5.25 5.68.41.36.78 1.06.78 2.14 0 1.55-.01 2.8-.01 3.18 0 .31.21.68.8.56A10.52 10.52 0 0 0 23.5 12C23.5 5.73 18.27.5 12 .5z"/></svg>
                    Sign in with GitHub
                </a>
                <p id="githubStatus" class="github-status">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l7 4v6c0 5-3.5 8-7 10-3.5-2-7-5-7-10V6l7-4z" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    Sign-in keeps the faucet fair. Accounts must be 30+ days old; one claim per account every <%= locals.rateLimitWindowHours ?? 8 %> hours.
                </p>
                <p class="gate-help">Some accounts may not pass verification. Trouble claiming? <a href="https://discord.com/invite/HGG52EtTc2" target="_blank" rel="noopener">Ask on the ar.io Discord</a>.</p>
            </div>

            <div id="githubSignedIn" class="github-signedin hidden">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M20 6L9 17l-5-5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                <span>Signed in<span id="githubUserLabel"></span> &mdash; you can claim now.</span>
            </div>

            <div>
                <label for="qty">Amount (ARIO)</label>
                <input type="number" id="qty" name="qty" required step="any"
                    min="<%= (locals.minQty ?? 10000000) / Math.pow(10, locals.decimals ?? 6) %>"
                    max="<%= (locals.maxQty ?? 10000000000) / Math.pow(10, locals.decimals ?? 6) %>"
                    value="<%= (locals.defaultQty ?? 10000000000) / Math.pow(10, locals.decimals ?? 6) %>">
            </div>

            <% if (captchaSiteKey) { %>
            <div>
                <label>Captcha</label>
                <div class="h-captcha" data-sitekey="<%= captchaSiteKey %>" data-size="normal" data-theme="light"></div>
            </div>
            <% } %>

            <button type="submit" id="submitButton" class="submit-btn">
                <span id="buttonText">Request Tokens</span>
                <svg id="loadingSpinner" class="spinner hidden" viewBox="0 0 24 24" fill="none">
                    <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" opacity="0.25"></circle>
                    <path fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                </svg>
            </button>
        </form>

        <div id="resultContainer" class="result hidden">
            <h3>Token request successful</h3>
            <p>Transfer ID:</p>
            <p id="tokenResult" class="mono"></p>
            <p>
                <button id="copyToken" class="link-btn">Copy to clipboard</button>
                &nbsp;&middot;&nbsp;
                <a id="aoExplorerLink" href="#" target="_blank" rel="noopener">View on Solana Explorer</a>
            </p>
            <div class="whats-next">
                <p class="wn-title">What&rsquo;s next?</p>
                <a class="wn-primary" href="https://console.ar.io" target="_blank" rel="noopener">Open the ar.io Console &rarr;</a>
                <p class="wn-hint">Stake your tokens or register an ArNS name in the Console.</p>
                <div class="wn-links">
                    <a href="https://faucet.solana.com" target="_blank" rel="noopener">Get devnet SOL</a>
                    <a href="https://docs.ar.io/build/guides" target="_blank" rel="noopener">Build guides</a>
                    <a href="https://github.com/ar-io/ar-io-sdk" target="_blank" rel="noopener">ar.io SDK</a>
                    <a href="https://docs.ar.io/sdks/turbo-sdk" target="_blank" rel="noopener">Turbo SDK</a>
                    <a href="https://github.com/ar-io/ar-io-deploy" target="_blank" rel="noopener">ar-io-deploy</a>
                </div>
            </div>
        </div>

        <div id="errorContainer" class="error-box hidden">
            <h3>Something went wrong</h3>
            <p id="errorMessage"></p>
            <p class="error-help">Still stuck? <a href="https://discord.com/invite/HGG52EtTc2" target="_blank" rel="noopener">Ask on the ar.io Discord</a>.</p>
        </div>
    </main>

    <section class="endpoints">
        <p class="endpoints-title">AR.IO Testnet endpoints</p>
        <p class="endpoints-sub">Point your tools here once you have ARIO &mdash; Solana devnet, staging ARIO.</p>
        <ul>
            <li><span>Upload API</span><a href="https://upload.services.ar-io.dev" target="_blank" rel="noopener">upload.services.ar-io.dev</a></li>
            <li><span>Payment API</span><a href="https://payment.services.ar-io.dev" target="_blank" rel="noopener">payment.services.ar-io.dev</a></li>
            <li><span>Gateway</span><a href="https://ar-io.dev" target="_blank" rel="noopener">ar-io.dev</a></li>
        </ul>

        <div class="ids-divider"></div>

        <p class="endpoints-title">Solana devnet program &amp; mint IDs</p>
        <p class="endpoints-sub">Click any ID to copy.</p>
        <div class="ids">
            <div class="id-row"><span>ARIO mint</span><code class="id-val" title="Click to copy">6vTw5CysRXQ4ybbHkDUiisHWVsBeMtUzYvJqs2iqHyaN</code></div>
            <div class="id-row"><span>ario-core program</span><code class="id-val" title="Click to copy">8Njx9wPkXiNzDCgjwVsJFRjpAEV34gGW3n8DzX3V23m1</code></div>
            <div class="id-row"><span>ario-gar program</span><code class="id-val" title="Click to copy">7WsDTrtZBsfKtnP33XkjuqXCY69JE7n4QVYpynqJCFxz</code></div>
            <div class="id-row"><span>ario-arns program</span><code class="id-val" title="Click to copy">6EZNezcg4rc5hnh8HG34vGquT3WpW5xXypzPb24uyEpp</code></div>
            <div class="id-row"><span>ario-ant program</span><code class="id-val" title="Click to copy">DbHbRwUD1oAn1mrDSqtWtvwGcNrmhWdD2g8L4xmeQ7NX</code></div>
        </div>
    </section>

    <footer>
        <div class="links">
            <a href="https://console.ar.io" target="_blank" rel="noopener">Console</a>
            <span class="sep">&middot;</span>
            <a href="https://docs.ar.io/build/guides" target="_blank" rel="noopener">Docs</a>
            <span class="sep">&middot;</span>
            <a href="https://github.com/ar-io/ar-io-sdk" target="_blank" rel="noopener">ar.io SDK</a>
            <span class="sep">&middot;</span>
            <a href="https://docs.ar.io/sdks/turbo-sdk" target="_blank" rel="noopener">Turbo SDK</a>
            <span class="sep">&middot;</span>
            <a href="https://github.com/ar-io/ar-io-deploy" target="_blank" rel="noopener">ar-io-deploy</a>
            <span class="sep">&middot;</span>
            <a href="https://discord.com/invite/HGG52EtTc2" target="_blank" rel="noopener">Discord</a>
        </div>
        <div class="copy">&copy; 2026 <a href="https://ar.io" target="_blank" rel="noopener">ar.io</a>. All rights reserved.</div>
    </footer>

    <script>
        const githubOAuthEnabled = <%= githubOAuthEnabled ? 'true' : 'false' %>;
        const captchaEnabled = <%= captchaSiteKey ? 'true' : 'false' %>;
        const tokenId = '<%= tokenId %>';

        // Amounts are entered in whole ARIO but the API expects base units
        // (integer, scaled by the token's decimals). Values come from the backend
        // with safe fallbacks for the static/permaweb build (ARIO devnet = 6 dp).
        const TOKEN_DECIMALS = <%= locals.decimals ?? 6 %>;
        const MIN_QTY = <%= locals.minQty ?? 10000000 %>;
        const MAX_QTY = <%= locals.maxQty ?? 10000000000 %>;
        const QTY_FACTOR = Math.pow(10, TOKEN_DECIMALS);

        // Signing in with GitHub is a full-page redirect to github.com and back,
        // which would otherwise clear the form. Persist the inputs before leaving
        // and restore them on return (sessionStorage survives the round-trip).
        const FORM_KEY = 'arioFaucetForm';
        (function restoreForm() {
            try {
                const s = JSON.parse(sessionStorage.getItem(FORM_KEY) || '{}');
                if (s.recipient) document.getElementById('recipient').value = s.recipient;
                if (s.qty) document.getElementById('qty').value = s.qty;
            } catch (e) {}
        })();

        // The claim token is NOT exposed to JS / the URL. The OAuth callback sets it
        // in an HttpOnly, Secure cookie scoped to /api and redirects back with
        // `?github=1&gh_user=<login>` purely as UI signals. The cookie is sent
        // automatically on the claim request (credentials: 'include').
        let githubSignedIn = false;
        let githubUser = '';
        (function readGithubSignal() {
            const params = new URLSearchParams(location.search);
            if (params.get('github') === '1') {
                githubSignedIn = true;
                githubUser = params.get('gh_user') || '';
                params.delete('github');
                params.delete('gh_user');
                const qs = params.toString();
                history.replaceState(null, '', location.pathname + (qs ? `?${qs}` : ''));
            }
        })();

        if (githubOAuthEnabled) {
            const gate = document.getElementById('githubGate');
            const link = document.getElementById('githubLoginLink');
            const signedInBox = document.getElementById('githubSignedIn');
            link.href = `<%= baseUrl %>/api/auth/github/login?process-id=${encodeURIComponent(tokenId)}`;
            // Save the form before the redirect so it's restored when we return.
            link.addEventListener('click', function() {
                try {
                    sessionStorage.setItem(FORM_KEY, JSON.stringify({
                        recipient: document.getElementById('recipient').value,
                        qty: document.getElementById('qty').value
                    }));
                } catch (e) {}
            });
            if (githubSignedIn) {
                if (githubUser) document.getElementById('githubUserLabel').textContent = ' as @' + githubUser;
                signedInBox.classList.remove('hidden');
            } else {
                gate.classList.remove('hidden');
            }
        }

        document.getElementById('tokenRequestForm').addEventListener('submit', async function(e) {
            e.preventDefault();

            let hcaptchaResponse = '';
            if (captchaEnabled) {
                hcaptchaResponse = (typeof hcaptcha !== 'undefined') ? hcaptcha.getResponse() : '';
                if (!hcaptchaResponse) { showError('Please complete the captcha.'); return; }
            }

            if (githubOAuthEnabled && !githubSignedIn) {
                showError('Please sign in with GitHub before claiming.');
                return;
            }

            const recipient = document.getElementById('recipient').value;
            const processId = document.getElementById('processId').value;
            const amount = parseFloat(document.getElementById('qty').value);
            if (!(amount > 0)) { showError('Enter a valid amount.'); return; }
            const qtyBase = Math.round(amount * QTY_FACTOR);
            if (qtyBase < MIN_QTY || qtyBase > MAX_QTY) {
                showError(`Amount must be between ${MIN_QTY / QTY_FACTOR} and ${MAX_QTY / QTY_FACTOR} ARIO.`);
                return;
            }

            showLoading();

            const payload = { processId, recipient, qty: qtyBase };
            if (captchaEnabled) payload.captchaResponse = hcaptchaResponse;

            try {
                const response = await fetch('<%= baseUrl %>/api/claim/sync', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    credentials: 'include',
                    body: JSON.stringify(payload)
                });

                if (!response.ok) {
                    const body = await response.json().catch(() => ({ error: response.statusText }));
                    throw new Error(body.error || 'Request failed');
                }

                const data = await response.json();
                showResult(data.id);
            } catch (error) {
                showError(error.message);
            }
        });

        function showLoading() {
            document.getElementById('submitButton').disabled = true;
            document.getElementById('loadingSpinner').classList.remove('hidden');
            document.getElementById('buttonText').textContent = 'Processing...';
        }

        function hideLoading() {
            document.getElementById('submitButton').disabled = false;
            document.getElementById('loadingSpinner').classList.add('hidden');
            document.getElementById('buttonText').textContent = 'Request Tokens';
        }

        function resetCaptcha() {
            if (captchaEnabled && typeof hcaptcha !== 'undefined') hcaptcha.reset();
        }

        function showResult(id) {
            document.getElementById('tokenResult').textContent = id;
            document.getElementById('aoExplorerLink').href = `https://explorer.solana.com/tx/${id}?cluster=devnet`;
            document.getElementById('resultContainer').classList.remove('hidden');
            document.getElementById('errorContainer').classList.add('hidden');
            document.getElementById('tokenRequestForm').reset();
            try { sessionStorage.removeItem(FORM_KEY); } catch (e) {}
            resetCaptcha();
            hideLoading();
        }

        function humanizeAmounts(msg) {
            // Backend messages interpolate raw base-unit token amounts. Reformat
            // any long integer run into human-readable ARIO, e.g.
            // 10000000000 -> "10,000 ARIO", 10000000 -> "10 ARIO". Base58 addresses
            // in the same message never contain 7+ consecutive digits.
            return String(msg).replace(/\b\d{7,}\b/g, function (m) {
                const n = Number(m) / QTY_FACTOR;
                if (!isFinite(n)) return m;
                return n.toLocaleString('en-US', { maximumFractionDigits: TOKEN_DECIMALS }) + ' ARIO';
            });
        }

        function showError(message) {
            document.getElementById('errorMessage').textContent = humanizeAmounts(message);
            document.getElementById('errorContainer').classList.remove('hidden');
            document.getElementById('resultContainer').classList.add('hidden');
            resetCaptcha();
            hideLoading();
        }

        document.getElementById('copyToken').addEventListener('click', function() {
            const tokenText = document.getElementById('tokenResult').textContent;
            navigator.clipboard.writeText(tokenText).then(() => {
                this.textContent = 'Copied!';
                setTimeout(() => { this.textContent = 'Copy to clipboard'; }, 2000);
            });
        }.bind(document.getElementById('copyToken')));

        // Click-to-copy the Solana program/mint IDs
        document.querySelectorAll('.id-val').forEach(function (el) {
            el.addEventListener('click', function () {
                navigator.clipboard.writeText(el.textContent.trim()).then(function () {
                    el.classList.add('copied');
                    setTimeout(function () { el.classList.remove('copied'); }, 1200);
                });
            });
        });
    </script>
</body>
</html>
